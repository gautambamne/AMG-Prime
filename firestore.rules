rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public content — anyone can read, only authenticated admins can write
    match /videos/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'jitbanerjeesujan@gmail.com',
        'rahul6pal9@gmail.com',
        'gautam2003b@gmail.com'
      ];
    }

    match /articles/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'jitbanerjeesujan@gmail.com',
        'rahul6pal9@gmail.com',
        'gautam2003b@gmail.com'
      ];
    }

    match /magazines/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'jitbanerjeesujan@gmail.com',
        'rahul6pal9@gmail.com',
        'gautam2003b@gmail.com'
      ];
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'jitbanerjeesujan@gmail.com',
        'rahul6pal9@gmail.com',
        'gautam2003b@gmail.com'
      ];
    }

    // Users can only read/write their own profile and sub-collections
    match /users/{userId} {
      allow list, read: if request.auth != null && request.auth.token.email in [
        'jitbanerjeesujan@gmail.com',
        'rahul6pal9@gmail.com',
        'gautam2003b@gmail.com'
      ];
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /bookmarks/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /downloads/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
